{
  "id": "af:registry/states",
  "kind": "StateRegistry",
  "version": "1.0.0",
  "schema": "https://schema.agennext.dev/agent-fabric/meta/state.schema.json",
  "states": [
    { "name": "proposed", "description": "Asserted but not yet active." },
    { "name": "active", "description": "Live and in effect (default)." },
    { "name": "degraded", "description": "Active but impaired." },
    { "name": "suspended", "description": "Temporarily inactive, may resume." },
    { "name": "retired", "description": "Permanently decommissioned." },
    { "name": "deleted", "description": "Tombstoned." }
  ]
}
