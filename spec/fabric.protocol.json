    "contains",
    "produces",
    "consumes",
    "observes",
    "emits",
    "tracedBy",
    "evidencedBy",
    "trusts",
    "delegatesTo",
    "reportsTo",
    "contractsWith",
    "boundBy",
    "reconciles",
    "approves",
    "rejects",
