{
  "name": "Agent-Fabric Protocol",
  "version": "0.1.0",
  "description": "Governed operational fabric protocol for agents, humans, tools, boxes, commitments, authority, reconciliation, and projected state.",
  "principles": [
    "Validation is evidence",
    "Authority is permission",
    "Reconciliation is judgment",
    "Projection is current reality",
    "No autonomous action without intent",
    "No claim without trace",
    "No stable state without reconciliation"
  ],
  "coreRecords": [
    "Node",
    "Relationship",
    "Intent",
    "CommitmentRecord",
    "Event",
    "Trace",
    "GapFillProposal",
    "ValidationReport",
    "AuthorityChain",
    "AuthorityGrant",
    "AuthorityDelegation",
    "ReconciliationRecord",
    "StateProjectionContract",
    "State"
  ],
  "topology": [
    "Federation",
    "Domain",
    "Cluster",
    "Box",
    "Participant"
  ],
  "messages": [
    "Observe",
    "Propose",
    "Validate",
    "Authorize",
    "Approve",
    "Reject",
    "Commit",
    "Challenge",
    "Reconcile",
    "Project",
    "Query",
    "Notify"
  ],
  "riskLevels": ["low", "medium", "high", "critical"],
  "lifecycleStates": [
    "draft",
    "proposed",
    "validating",
    "needsEvidence",
    "needsAuthority",
    "needsContract",
    "approved",
    "active",
    "degraded",
