{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/relationship.schema.json",
  "title": "Fabric Relationship",
  "type": "object",
  "required": [
    "id",
    "subject",
    "predicate",
    "object",
    "status",
    "authority",
    "risk",
    "evidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "subject": { "type": "string" },
    "predicate": { "type": "string" },
    "object": { "type": "string" },
    "status": {
      "enum": ["proposed", "validating", "active", "challenged", "superseded", "retired", "rejected"]
    },
    "authority": {
      "enum": ["system", "agent", "policy", "human", "platform"]
    },
    "risk": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
