{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/state.schema.json",
  "title": "Fabric State",
  "type": "object",
  "required": ["id", "version", "health", "derivedFrom"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "health": {
      "enum": ["stable", "degraded", "drifting", "reconciling", "failed"]
    },
    "relationships": {
      "type": "array",
      "items": { "type": "string" }
    },
    "derivedFrom": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
