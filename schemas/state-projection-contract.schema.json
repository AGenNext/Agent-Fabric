{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/state-projection-contract.schema.json",
  "title": "Fabric StateProjectionContract",
  "type": "object",
  "required": ["id", "projectionName", "sourceStreams", "projectionRules", "outputStateType", "version", "status"],
  "properties": {
    "id": { "type": "string" },
    "projectionName": { "type": "string" },
    "sourceStreams": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "projectionRules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "orderingRules": { "type": "array", "items": { "type": "string" } },
    "conflictRules": { "type": "array", "items": { "type": "string" } },
    "replayRules": { "type": "array", "items": { "type": "string" } },
    "outputStateType": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "active", "deprecated", "retired"] }
  }
}
