{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/commitment-record.schema.json",
  "title": "Fabric CommitmentRecord",
  "description": "Operational promise between debtor and creditor with obligations, conditions, evidence, authority, and lifecycle.",
  "type": "object",
  "required": ["id", "type", "debtor", "creditor", "scope", "condition", "obligations", "status", "evidence", "temporal"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": { "const": "CommitmentRecord" },
    "debtor": { "type": "string", "minLength": 1 },
    "creditor": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "condition": { "type": "string", "minLength": 1 },
    "obligations": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "dueAt": { "type": ["string", "null"], "format": "date-time" },
    "status": { "enum": ["offered", "accepted", "active", "fulfilled", "violated", "released", "cancelled", "expired", "superseded"] },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "authorityChain": { "type": "string" },
    "temporal": { "type": "object" }
  }
}
