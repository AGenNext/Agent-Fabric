{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/node.schema.json",
  "title": "Fabric Node",
  "description": "Any stable addressable thing in the Agent-Fabric.",
  "type": "object",
  "required": ["id", "type", "name", "status", "createdAt"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": {
      "type": "string",
      "enum": [
        "Human",
        "Agent",
        "Tool",
        "Skill",
        "Model",
        "Runtime",
        "Kernel",
        "Workspace",
        "Policy",
        "Organization",
        "Team",
        "Document",
        "Decision",
        "Contract",
        "Service",
        "System",
        "Resource",
        "Event",
        "Trace",
        "Proposal",
        "Reconciliation",
        "State",
        "DigitalTwin"
      ]
    },
    "name": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "active", "suspended", "retired", "archived"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "version": { "type": "integer", "minimum": 1 },
    "metadata": { "type": "object" }
  }
}
