{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/gap-fill-proposal.schema.json",
  "title": "Fabric GapFillProposal",
  "description": "A proposed completion for missing, weak, stale, or conflicting fabric state.",
  "type": "object",
  "required": [
    "id",
    "type",
    "gapType",
    "subject",
    "proposedChange",
    "confidence",
    "risk",
    "evidence",
    "proposedBy",
    "approvalRequired",
    "status",
    "temporal"
  ],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": { "const": "GapFillProposal" },
    "gapType": {
      "type": "string",
      "enum": [
        "missingNode",
        "missingRelationship",
        "missingIdentity",
        "missingEvidence",
        "missingContract",
        "policyDrift",
        "runtimeDrift",
        "authorityDrift",
        "trustDrift",
        "schemaDrift",
        "conflictDrift",
        "orphanDrift",
        "vocabularyGap"
      ]
    },
    "subject": { "type": "string", "minLength": 1 },
    "proposedChange": { "type": "object" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "risk": { "enum": ["low", "medium", "high", "critical"] },
    "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "proposedBy": { "type": "string", "minLength": 1 },
    "approvalRequired": { "type": "boolean" },
    "status": {
      "enum": [
        "proposed",
        "validating",
        "needsEvidence",
        "needsAuthority",
        "accepted",
        "rejected",
        "quarantined",
        "superseded"
      ]
    },
    "temporal": {
      "type": "object",
      "required": ["observedAt", "recordedAt"],
      "properties": {
        "observedAt": { "type": "string", "format": "date-time" },
        "recordedAt": { "type": "string", "format": "date-time" },
        "effectiveAt": { "type": ["string", "null"], "format": "date-time" },
        "validFrom": { "type": ["string", "null"], "format": "date-time" },
        "validTo": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
