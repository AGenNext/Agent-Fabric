{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agennext.com/fabric/vocabulary-governance.schema.json",
  "title": "Fabric VocabularyGovernance",
  "type": "object",
  "required": ["id", "term", "termType", "definition", "proposedBy", "status"],
  "properties": {
    "id": { "type": "string" },
    "term": { "type": "string" },
    "termType": { "enum": ["predicate", "nodeType", "riskClass", "statusValue", "recordType"] },
    "definition": { "type": "string" },
    "proposedBy": { "type": "string" },
    "reason": { "type": "string" },
    "impact": { "type": "string" },
    "status": { "enum": ["proposed", "reviewing", "accepted", "rejected", "deprecated", "superseded", "retired"] },
    "reviewers": { "type": "array", "items": { "type": "string" } },
    "approvers": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": ["string", "null"] }
  }
}
