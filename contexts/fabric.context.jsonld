{
  "@context": {
    "id": "@id",
    "type": "@type",
    "schema": "https://schema.org/",
    "prov": "http://www.w3.org/ns/prov#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "fabric": "https://fabric.agennext.com/ns#",

    "Node": "fabric:Node",
    "Relationship": "fabric:Relationship",
    "Intent": "fabric:Intent",
    "CommitmentRecord": "fabric:CommitmentRecord",
    "GapFillProposal": "fabric:GapFillProposal",
    "AuthorityChain": "fabric:AuthorityChain",
    "AuthorityGrant": "fabric:AuthorityGrant",
    "AuthorityDelegation": "fabric:AuthorityDelegation",
    "AuthorityRequest": "fabric:AuthorityRequest",
    "AuthorityResult": "fabric:AuthorityResult",
    "ValidationReport": "fabric:ValidationReport",
    "ReconciliationRecord": "fabric:ReconciliationRecord",
    "StateProjectionContract": "fabric:StateProjectionContract",
    "State": "fabric:State",
    "ProjectedState": "fabric:ProjectedState",
    "Event": "fabric:Event",
    "Trace": "fabric:Trace",

    "FabricFederation": "fabric:FabricFederation",
    "FabricDomain": "fabric:FabricDomain",
    "FabricCluster": "fabric:FabricCluster",
    "FabricBox": "fabric:FabricBox",
    "FabricParticipant": "fabric:FabricParticipant",

    "Observe": "fabric:Observe",
    "Propose": "fabric:Propose",
    "Validate": "fabric:Validate",
    "Authorize": "fabric:Authorize",
    "Approve": "fabric:Approve",
    "Reject": "fabric:Reject",
    "Commit": "fabric:Commit",
    "Challenge": "fabric:Challenge",
    "Reconcile": "fabric:Reconcile",
    "Project": "fabric:Project",
    "Query": "fabric:Query",
    "Notify": "fabric:Notify",

    "subject": { "@id": "fabric:subject", "@type": "@id" },
    "predicate": { "@id": "fabric:predicate" },
    "object": { "@id": "fabric:object", "@type": "@id" },
    "source": { "@id": "fabric:source", "@type": "@id" },
    "recipient": { "@id": "fabric:recipient", "@type": "@id" },
    "intent": { "@id": "fabric:intent", "@type": "@id" },
    "identity": { "@id": "fabric:identity", "@type": "@id" },
    "trace": { "@id": "fabric:trace", "@type": "@id" },
    "evidence": { "@id": "prov:wasDerivedFrom", "@type": "@id" },
    "authorityChain": { "@id": "fabric:authorityChain", "@type": "@id" },
    "risk": "fabric:risk",
    "status": "fabric:status",
    "lifecycle": "fabric:lifecycle",

    "federation": { "@id": "fabric:federation", "@type": "@id" },
    "domain": { "@id": "fabric:domain", "@type": "@id" },
    "cluster": { "@id": "fabric:cluster", "@type": "@id" },
    "box": { "@id": "fabric:box", "@type": "@id" },
    "participant": { "@id": "fabric:participant", "@type": "@id" },

    "desiredState": { "@id": "fabric:desiredState", "@type": "@id" },
    "observedState": { "@id": "fabric:observedState", "@type": "@id" },
    "currentState": { "@id": "fabric:currentState", "@type": "@id" },
    "projectedState": { "@id": "fabric:projectedState", "@type": "@id" },
    "derivedFrom": { "@id": "prov:wasDerivedFrom", "@type": "@id" },

    "observedAt": { "@id": "fabric:observedAt", "@type": "xsd:dateTime" },
    "recordedAt": { "@id": "fabric:recordedAt", "@type": "xsd:dateTime" },
    "effectiveAt": { "@id": "fabric:effectiveAt", "@type": "xsd:dateTime" },
    "validFrom": { "@id": "fabric:validFrom", "@type": "xsd:dateTime" },
    "validTo": { "@id": "fabric:validTo", "@type": "xsd:dateTime" },
    "expiresAt": { "@id": "fabric:expiresAt", "@type": "xsd:dateTime" },
    "reconciledAt": { "@id": "fabric:reconciledAt", "@type": "xsd:dateTime" },
    "projectedAt": { "@id": "fabric:projectedAt", "@type": "xsd:dateTime" }
  }
}
